# ============================================================
# AI Studio - Git Ignore
# ============================================================

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd

# Python packaging
*.egg-info/
.eggs/
pip-wheel-metadata/

# ------------------------------------------------------------
# Virtual Environments
# ------------------------------------------------------------
.venv/
venv/
env/
ENV/

# Local environment configuration
.env
.env.*
!.env.example

# ------------------------------------------------------------
# Python Testing
# ------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.hypothesis/

# ------------------------------------------------------------
# IDE / Editors
# ------------------------------------------------------------
.vscode/
.idea/
*.code-workspace

# ------------------------------------------------------------
# Node / Frontend
# ------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ------------------------------------------------------------
# Build Artifacts
# ------------------------------------------------------------
build/
dist/
site/

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------
*.log
logs/

# ------------------------------------------------------------
# Runtime / Temporary Files
# ------------------------------------------------------------
*.tmp
*.temp
*.bak
*.swp
*.swo

# ------------------------------------------------------------
# Operating System
# ------------------------------------------------------------
Thumbs.db
.DS_Store
Desktop.ini

# ------------------------------------------------------------
# AI Studio Runtime
# ------------------------------------------------------------
workspace/
!workspace/.gitkeep

# ------------------------------------------------------------
# Local AI Models
# ------------------------------------------------------------
models/

# ------------------------------------------------------------
# AI Assistant Artifacts
# ------------------------------------------------------------
.aider*
.continue/sessions/
.continue/cache/

# ------------------------------------------------------------
# Miscellaneous
# ------------------------------------------------------------
test_filesystem_operation.txt